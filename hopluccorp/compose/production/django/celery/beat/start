#!/bin/bash
set -o errexit
set -o pipefail
set -o nounset

rm -f './celerybeat.pid'

# Wait for Django to finish migrations
until python -c "
import django
django.setup()
from django.db import connection
cursor = connection.cursor()
cursor.execute(\"SELECT 1 FROM information_schema.tables WHERE table_name='django_celery_beat_periodictask'\")
exit(0 if cursor.fetchone() else 1)
" 2>/dev/null; do
  echo "Migrations not ready yet, waiting 5s..."
  sleep 5
done

celery -A config.celery_app beat -l INFO --scheduler django_celery_beat.schedulers:DatabaseScheduler
